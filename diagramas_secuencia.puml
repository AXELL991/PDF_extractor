@startuml

!theme plain

skinparam sequenceArrowThickness 2

skinparam sequence {
    ArrowColor #333333
    LifeLineBorderColor #666666
    LifeLineBackgroundColor #F0F0F0
    ParticipantBorderColor #333333
    ParticipantBackgroundColor #E3F2FD
    ParticipantFontColor #000000
    ActorBackgroundColor #FFF3E0
    ActorBorderColor #333333
    NoteBackgroundColor #FFFDE7
    NoteBorderColor #FBC02D
}

skinparam wrapWidth 250
skinparam maxMessageSize 300
skinparam responseMessageBelowArrow true
skinparam shadowing false

skinparam participant {
    BackgroundColor<<External>> #FFEBEE
    BorderColor<<External>> #C62828
}

skinparam participant {
    BackgroundColor<<Service>> #E8F5E9
    BorderColor<<Service>> #2E7D32
}

skinparam participant {
    BackgroundColor<<Storage>> #E1F5FE
    BorderColor<<Storage>> #0277BD
}

title Diagrama de Secuencia - API Extractor de PDFs

actor "Usuario/Cliente" as User
participant "API FastAPI\n(main.py)" as API <<External>>
participant "PyPDFExtractor\n(pdf_extractor.py)" as Service <<Service>>
participant "MongoRepository\n(database.py)" as DB <<Storage>>
database "MongoDB" as Mongo

== Flujo Principal: Subir y Procesar un PDF ==

User -> API : POST /upload (PDF)
activate API #E3F2FD

alt Formato invalido
    API --> User : "400 Bad Request: El archivo proporcionado no es PDF."

else Formato valido

    note right of API
        Verifica que el archivo
        termine en ".pdf"
    end note

    alt Archivo muy grande

        API --> User : "413 Payload Too Large: El archivo supera los 5MB."

    else Tamano valido

        note right of API
            Verifica que el tamano
            sea menor a 5MB
        end note

        API -> API : Leer bytes del archivo en RAM

        note right of API
            io.BytesIO guarda el archivo
            en memoria sin usar disco
        end note

        API -> Service : calculate_checksum(bytes)

        activate Service #E8F5E9

        Service -> Service : file.seek(0) + sha256

        Service --> API : checksum SHA-256

        deactivate Service

        API -> DB : obtener_por_checksum(checksum)

        activate DB #E1F5FE

        DB -> Mongo : find_one({"hash_seguridad": ...})

        activate Mongo

        Mongo --> DB : documento

        deactivate Mongo

        DB --> API : documento o None

        deactivate DB

        alt Documento duplicado

            API --> User : "409 Conflict: Este PDF ya fue procesado."

        else Documento nuevo

            API -> Service : extract(bytes)

            activate Service #E8F5E9

            Service -> Service : PdfReader(pages) -> texto

            Service --> API : texto_extraido

            deactivate Service

            API -> DB : guardar_documento(nombre, texto, checksum)

            activate DB #E1F5FE

            DB -> Mongo : insert_one(documento)

            activate Mongo

            Mongo --> DB : resultado insert

            deactivate Mongo

            DB --> API : resultado

            deactivate DB

            API --> User : "200 OK: UploadResponse"

            note right of API
                {
                  "status": "success",
                  "message": "Documento procesado",
                  "filename": "...",
                  "sha256": "..."
                }
            end note

        end
    end
end

deactivate API

== Operaciones CRUD Adicionales ==

User -> API : GET /documentos

activate API #E3F2FD

API -> DB : listar_todos()

activate DB #E1F5FE

DB -> Mongo : find({}, {"_id": 0})

activate Mongo

Mongo --> DB : lista documentos

deactivate Mongo

DB --> API : documentos

deactivate DB

API --> User : "200 OK: {total, documentos}"

deactivate API

User -> API : GET /documentos/{checksum}

activate API #E3F2FD

API -> DB : obtener_por_checksum(checksum)

activate DB #E1F5FE

DB -> Mongo : find_one({...})

activate Mongo

Mongo --> DB : documento o None

deactivate Mongo

DB --> API : documento

deactivate DB

alt Documento no encontrado

    API --> User : "404 Not Found"

else Documento encontrado

    API --> User : "200 OK: documento"

end

deactivate API

User -> API : PUT /documentos/{checksum} (nuevo_nombre)

activate API #E3F2FD

API -> DB : obtener_por_checksum(checksum)

activate DB #E1F5FE

DB -> Mongo : find_one({...})

activate Mongo

Mongo --> DB : documento

deactivate Mongo

DB --> API : documento

deactivate DB

alt Documento no encontrado

    API --> User : "404 Not Found"

else Documento encontrado

    API -> DB : actualizar_nombre(checksum, nuevo_nombre)

    activate DB #E1F5FE

    DB -> Mongo : update_one({...}, {$set: {...}})

    activate Mongo

    Mongo --> DB : resultado

    deactivate Mongo

    DB --> API : resultado

    deactivate DB

    API --> User : "200 OK: Nombre actualizado"

end

deactivate API

User -> API : DELETE /documentos/{checksum}

activate API #E3F2FD

API -> DB : obtener_por_checksum(checksum)

activate DB #E1F5FE

DB -> Mongo : find_one({...})

activate Mongo

Mongo --> DB : documento

deactivate Mongo

DB --> API : documento

deactivate DB

alt Documento no encontrado

    API --> User : "404 Not Found"

else Documento encontrado

    API -> DB : eliminar_documento(checksum)

    activate DB #E1F5FE

    DB -> Mongo : delete_one({...})

    activate Mongo

    Mongo --> DB : resultado

    deactivate Mongo

    DB --> API : resultado

    deactivate DB

    API --> User : "200 OK: Documento eliminado"

end

deactivate API

@enduml