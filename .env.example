# ============================================
# CONFIGURACIÓN PDF EXTRACTOR - ETAPA 1
# ============================================

# --- CONFIGURACIÓN BASE DE DATOS (MongoDB) ---
# Puerto por defecto donde va a correr el contenedor de Docker
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=pdf_extractor_db

# ============================================
# NOTAS DE ARQUITECTURA (KISS / YAGNI):
# - PDF_FILE_PATH: Eliminado. Los PDFs viajan por red y se leen en RAM.
# - AI_PROVIDER / OLLAMA / MOONSHOT: Omitidos temporalmente. 
#   No son parte de los requerimientos de la Etapa 1.
# ============================================