# ============================================
# CONFIGURACIÓN PDF EXTRACTOR
# Copia este archivo como .env y completa tus valores
# ============================================

# --- CONFIGURACIÓN PDF ---
PDF_FILE_PATH=documento.pdf

# --- CONFIGURACIÓN BASE DE DATOS (MongoDB) ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=pdf_summaries

# --- CONFIGURACIÓN PROVEEDOR DE IA ---
# Opciones: "ollama" (local) o "moonshot" (API de Kimi K2.5)
AI_PROVIDER=ollama

# --- CONFIGURACIÓN OLLAMA (si AI_PROVIDER=ollama) ---
AI_MODEL=llama3
AI_API_URL=http://localhost:11434/api/generate

# --- CONFIGURACIÓN MOONSHOT/KIMI (si AI_PROVIDER=moonshot) ---
# Obtén tu API key en: https://platform.moonshot.cn/
MOONSHOT_API_KEY=tu_api_key_aqui
MOONSHOT_MODEL=moonshotai/kimi-k2.5
