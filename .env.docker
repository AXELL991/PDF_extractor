# ============================================
# CONFIGURACION PDF EXTRACTOR - Docker Compose
# ============================================

# --- CONFIGURACION BASE DE DATOS (MongoDB) ---
# URI de conexion a MongoDB (usando el servicio 'mongodb' de docker-compose)
MONGO_URI=mongodb://admin:admin123@mongodb:27017/pdf_extractor_db?authSource=admin
MONGO_DB_NAME=pdf_extractor_db

# --- CONFIGURACION API ---
# Puerto donde correra la API dentro del contenedor
API_PORT=8000

